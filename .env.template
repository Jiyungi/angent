# ============================================
# HARNESS ENGINEERING HACK - ENV TEMPLATE
# June 12, 2026
# ============================================

# === TrueFoundry (AI Gateway - routes all LLM calls) ===
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_BASE_URL=

# === AWS Bedrock (LLM provider, routed through TrueFoundry) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# === Pioneer (self-improving inference - get promo code at event) ===
PIONEER_API_KEY=

# === Guild.ai (agent control plane) ===
# Login via: guild auth login (browser-based)
GUILD_API_KEY=

# === Airbyte (data/context layer for agent) ===
# Sign up at: https://app.airbyte.ai
AIRBYTE_CLIENT_ID=
AIRBYTE_CLIENT_SECRET=

# === ClickHouse (analytical database) ===
# Sign up at: https://console.clickhouse.cloud
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# === OpenUI (generative UI framework - by Thesys) ===
# No API key needed - it's an open-source framework
# Install: npm install @openui/react
# Docs: https://www.openui.com

# === Langfuse (LLM observability / tracing) ===
# Find these in Langfuse UI -> Settings -> API Keys. Leave blank to run untraced
# (the loop runs identically with a safe disabled fallback).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
